---
const title = 'Narayaneeyam';
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root{--bg:#0b0c10;--card:#12141c;--text:#e8eaf2;--muted:#a7adc2;--accent:#c8a24a;}
      body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto; background:var(--bg); color:var(--text);}
      .wrap{max-width:820px;margin:0 auto;padding:24px;}
      h1{font-size:28px;margin:8px 0 6px;}
      p{color:var(--muted);line-height:1.5}
      a{color:var(--accent);text-decoration:none}
      .card{background:var(--card);border:1px solid rgba(255,255,255,.08);border-radius:16px;padding:16px;margin-top:16px}
      .btn{display:inline-block;background:rgba(200,162,74,.14);border:1px solid rgba(200,162,74,.35);padding:10px 12px;border-radius:12px}
    </style>
  </head>
  <body>
    <div class="wrap">
      <p style="margin:0;color:var(--muted)">Narayaneeyam</p>
      <h1>Narayaneeyam</h1>
      <p>Sanskrit + English meaning + reflections.</p>

      <div class="card">
        <h2 style="margin:0 0 8px">Daskam 1</h2>
        <p style="margin:0 0 12px">Brahma-tattva and the blessing of Guruvayur.</p>
        <a class="btn" href="/daskam/1">Open Daskam 1 →</a>
      </div>
    </div>
  </body>
</html>
