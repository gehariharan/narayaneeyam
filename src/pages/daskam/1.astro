---
import d01 from '../../content/daskam01.json';
const daskam = d01;
const lang = Astro.url.searchParams.get('lang') ?? 'en';
const isTa = lang === 'ta';
---
<html lang={isTa ? 'ta' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`Narayaneeyam — Daskam ${daskam.id}`}</title>
    <style>
      :root{--bg:#0b0c10;--card:#12141c;--text:#e8eaf2;--muted:#a7adc2;--accent:#c8a24a;}
      body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto; background:var(--bg); color:var(--text);}
      .wrap{max-width:860px;margin:0 auto;padding:18px 16px 60px;}
      a{color:var(--accent);text-decoration:none}
      .top{display:flex;align-items:center;justify-content:space-between;gap:12px;}
      .pill{display:inline-flex;gap:8px;align-items:center;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.10);padding:8px 10px;border-radius:999px;color:var(--muted);font-size:13px}
      .pill a{color:var(--text)}
      h1{font-size:22px;margin:14px 0 6px}
      .stanza{margin-top:16px;background:var(--card);border:1px solid rgba(255,255,255,.08);border-radius:18px;overflow:hidden}
      .img{aspect-ratio: 16/9; background: rgba(200,162,74,.08); display:flex;align-items:center;justify-content:center;color:var(--muted)}
      .img img{width:100%;height:100%;object-fit:cover;display:block}
      .content{padding:14px 14px 16px}
      .sa{white-space:pre-wrap;font-size:18px;line-height:1.55}
      .label{margin-top:12px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
      .para{margin:6px 0 0;line-height:1.6}
      .gloss{margin:8px 0 0;padding-left:16px;color:var(--muted)}
      .gloss li{margin:4px 0}
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="top">
        <a href="/">← All Daskams</a>
        <div class="pill">
          <span>Language:</span>
          <a href={`?lang=en`}>EN</a>
          <span style="opacity:.5">|</span>
          <a href={`?lang=ta`}>TA</a>
        </div>
      </div>

      <h1>Daskam {daskam.id}</h1>
      <p style="margin:0;color:var(--muted)">Sanskrit always shown. English meaning + your commentary. Tamil toggle scaffold.</p>

      {daskam.stanzas.map((s) => (
        <section class="stanza">
          <div class="img">
            {/* placeholder until images are generated */}
            <img src={s.image.src} alt={s.image.alt} onerror="this.remove(); this.parentElement.textContent='Image pending (to be generated)';" />
          </div>
          <div class="content">
            <div class="label">Sanskrit (Stanza {s.n})</div>
            <div class="sa">{s.sanskrit}</div>

            <div class="label">Word-by-word (English)</div>
            <ul class="gloss">
              {s.gloss_en.map((g) => (
                <li><span style="color:var(--text)">{g.sa}</span> — {g.en}</li>
              ))}
            </ul>

            <div class="label">Meaning</div>
            {!isTa ? (
              <p class="para">{s.meaning_en}</p>
            ) : (
              <p class="para" style="color:var(--muted)">{s.tamil.meaning_ta || 'Tamil coming soon.'}</p>
            )}

            <div class="label">Commentary</div>
            {!isTa ? (
              <p class="para">{s.commentary_en}</p>
            ) : (
              <p class="para" style="color:var(--muted)">{s.tamil.commentary_ta || 'Tamil commentary coming soon.'}</p>
            )}

            <p style="margin:14px 0 0;font-size:12px;color:var(--muted)">Source: <a href={daskam.source.sanskrit_english} target="_blank" rel="noreferrer">narayaneeyam-firststep.org</a></p>
          </div>
        </section>
      ))}
    </div>
  </body>
</html>
