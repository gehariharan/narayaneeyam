---
import d01 from '../../content/daskam01.json';
const daskam = d01;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`Narayaneeyam — Daskam ${daskam.id}`}</title>
    <style>
      :root{--bg:#0b0c10;--card:#12141c;--text:#e8eaf2;--muted:#a7adc2;--accent:#c8a24a;}
      body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto; background:var(--bg); color:var(--text);}
      .wrap{max-width:860px;margin:0 auto;padding:18px 16px 60px;}
      a{color:var(--accent);text-decoration:none}
      .top{display:flex;align-items:center;justify-content:space-between;gap:12px;}
      .pill{display:inline-flex;gap:8px;align-items:center;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.10);padding:8px 10px;border-radius:999px;color:var(--muted);font-size:13px}
      .pill a{color:var(--text)}
      h1{font-size:22px;margin:14px 0 6px}
      .carousel{margin-top:16px; display:flex; gap:14px; overflow-x:auto; padding: 4px 2px 12px; scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch}
      .carousel::-webkit-scrollbar{height:8px}
      .carousel::-webkit-scrollbar-thumb{background:rgba(255,255,255,.14); border-radius:999px}
      .stanza{flex: 0 0 min(92vw, 820px); scroll-snap-align:start; background:var(--card);border:1px solid rgba(255,255,255,.08);border-radius:18px;overflow:hidden}
      .img{aspect-ratio: 16/9; background: rgba(200,162,74,.08); display:flex;align-items:center;justify-content:center;color:var(--muted); position:relative}
      .img button{all:unset; cursor:pointer; display:block; width:100%; height:100%}
      .img img{width:100%;height:100%;object-fit:cover;display:block}
      .zoomHint{position:absolute; right:10px; bottom:10px; font-size:12px; color:rgba(232,234,242,.92); background:rgba(0,0,0,.35); padding:6px 8px; border-radius:999px; border:1px solid rgba(255,255,255,.18); backdrop-filter: blur(6px)}
      dialog{border:none; padding:0; background:transparent; max-width:min(96vw, 980px)}
      dialog::backdrop{background:rgba(0,0,0,.72)}
      .modal{background:rgba(18,20,28,.98); border:1px solid rgba(255,255,255,.12); border-radius:16px; overflow:hidden}
      .modal img{display:block; width:100%; height:auto; background:#0b0c10}
      .modalTop{display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px 12px; color:var(--muted)}
      .modalTop strong{color:var(--text); font-weight:600}
      .closeBtn{all:unset; cursor:pointer; padding:6px 10px; border-radius:10px; border:1px solid rgba(255,255,255,.14)}
      .content{padding:14px 14px 16px}
      .sa{white-space:pre-wrap;font-size:18px;line-height:1.55}
      .label{margin-top:12px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
      .lang-block{display:block}
      .lang-ta{display:none}
      .para{margin:6px 0 0;line-height:1.6}
      .gloss{margin:8px 0 0;padding-left:16px;color:var(--muted)}
      .gloss li{margin:4px 0}
      details{border-top:1px solid rgba(255,255,255,.08); padding-top:10px}
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="top">
        <a href="/">← All Daskams</a>
        <div class="pill">
          <span>English:</span>
          <a href="#" data-enmode="translation">Translation</a>
          <span style="opacity:.5">|</span>
          <a href="#" data-enmode="meaning">Meaning</a>
        </div>
      </div>

      <h1>Daskam {daskam.id}</h1>

      <div class="carousel" aria-label="Slokas">
      {daskam.stanzas.map((s, idx) => (
        <section class="stanza" aria-label={`Sloka ${s.n}`}>
          <div class="img">
            <button type="button" data-fullsrc={s.image.src} data-alt={s.image.alt} onclick="window.__na_openImg?.(this.dataset.fullsrc, this.dataset.alt)">
              <img src={s.image.src} alt={s.image.alt} onerror="this.remove(); this.parentElement.parentElement.textContent='Image pending (to be generated)';" />
            </button>
            <span class="zoomHint">Tap to zoom</span>
          </div>
          <div class="content">
            <div class="label">Sanskrit (Stanza {s.n})</div>
            <div class="sa">{s.sanskrit}</div>

            <div class="label">English</div>
            <p class="para en-block en-translation">{s.translation_en || s.meaning_en}</p>
            <p class="para en-block en-meaning" style="display:none">{s.meaning_en}</p>

            <details style="margin-top:10px">
              <summary style="cursor:pointer;color:var(--muted)">Word-by-word (optional)</summary>
              <ul class="gloss">
                {s.gloss_en.map((g) => (
                  <li><span style="color:var(--text)">{g.sa}</span> — {g.en}</li>
                ))}
              </ul>
            </details>

            <div class="label">Commentary</div>
            <p class="para">{s.commentary_en}</p>
          </div>
        </section>
      ))}

      <dialog id="imgModal">
        <div class="modal">
          <div class="modalTop">
            <strong id="imgModalTitle">Image</strong>
            <button class="closeBtn" type="button" onclick="document.getElementById('imgModal').close()">Close</button>
          </div>
          <img id="imgModalImg" alt="" />
        </div>
      </dialog>

      <script>
        // English switcher (Translation vs Meaning)
        const setEnMode = (mode) => {
          const showMeaning = mode === 'meaning';
          document.querySelectorAll('.en-translation').forEach(el => el.style.display = showMeaning ? 'none' : 'block');
          document.querySelectorAll('.en-meaning').forEach(el => el.style.display = showMeaning ? 'block' : 'none');
          document.querySelectorAll('[data-enmode]').forEach(a => {
            const active = a.dataset.enmode === mode;
            a.style.color = active ? 'var(--text)' : 'var(--muted)';
          });
          try { localStorage.setItem('na_en_mode', mode); } catch {}
        };
        const initialMode = (new URLSearchParams(window.location.search).get('en') || localStorage.getItem('na_en_mode') || 'translation');
        setEnMode(initialMode);
        document.querySelectorAll('[data-enmode]').forEach(a => {
          a.addEventListener('click', (e) => {
            e.preventDefault();
            setEnMode(a.dataset.enmode);
          });
        });

        window.__na_openImg = (src, alt) => {
          const dlg = document.getElementById('imgModal');
          const img = document.getElementById('imgModalImg');
          const title = document.getElementById('imgModalTitle');
          img.src = src;
          img.alt = alt || '';
          title.textContent = alt || 'Image';
          dlg.showModal();
        };
        document.getElementById('imgModal')?.addEventListener('click', (e) => {
          // click outside modal content closes
          if (e.target?.id === 'imgModal') e.target.close();
        });
      </script>

    </div>
  </body>
</html>
