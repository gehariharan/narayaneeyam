---
import { getPublishedDaskamIds, getDaskamContent } from '../../lib/get-content';
import type { DaskamData } from '../../lib/types';

export async function getStaticPaths() {
  const daskams = await getPublishedDaskamIds();
  return daskams.map(d => ({ params: { id: String(d.id) } }));
}

const { id } = Astro.params;
const daskam = await getDaskamContent(parseInt(id!, 10)) as DaskamData;
if (!daskam) return Astro.redirect('/');
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{`Narayaneeyam — Daskam ${daskam.id}`}</title>
    <meta name="description" content={`Daskam ${daskam.id} of Narayaneeyam — Sanskrit verses with English translations, commentary, and devotional artwork.`} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0b0c10" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`Narayaneeyam — Daskam ${daskam.id}`} />
    <meta property="og:description" content={`Sanskrit verses, English translations, and commentary for Daskam ${daskam.id}.`} />
    <meta property="og:image" content="/android-chrome-512x512.png" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`Narayaneeyam — Daskam ${daskam.id}`} />
    <meta name="twitter:description" content={`Sanskrit verses, English translations, and commentary for Daskam ${daskam.id}.`} />
    <meta name="twitter:image" content="/android-chrome-512x512.png" />
    <style>
      :root{--bg:#0b0c10;--card:#12141c;--text:#e8eaf2;--muted:#a7adc2;--accent:#c8a24a;}
      body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto; background:var(--bg); color:var(--text);}
      .wrap{max-width:860px;margin:0 auto;padding:18px 16px 60px;}
      a{color:var(--accent);text-decoration:none}
      .header{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
      .back{font-size:20px;color:var(--muted);text-decoration:none;line-height:1}
      .title{font-size:18px;font-weight:700;margin:0}
      .sep{color:rgba(255,255,255,.15)}
      .sloka-count{font-size:13px;color:var(--muted);white-space:nowrap}
      .dots-row{display:flex;gap:6px;align-items:center;justify-content:center;margin-top:6px}
      .dot{width:6px;height:6px;border-radius:999px;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.10)}
      .dot.active{background:rgba(200,162,74,.9);border-color:rgba(200,162,74,.7)}
      .dot-arrow{all:unset;cursor:pointer;color:var(--muted);font-size:16px;padding:2px 6px;line-height:1;transition:color .15s}
      .dot-arrow:hover{color:var(--accent)}
      .dot-arrow:disabled{opacity:.25;cursor:default}
      .lang-sw{display:inline-flex;gap:2px;align-items:center;font-size:13px;color:var(--muted);margin-left:auto}
      .lang-sw a{color:var(--muted);padding:2px 6px;border-radius:6px;text-decoration:none;font-weight:600}
      .lang-sw a.active{color:var(--text);background:rgba(255,255,255,.08)}

      /* stacked swipe cards */
      .stack-wrap{margin-top:12px; position:relative;}
      .stack{position:relative; height:min(82vh, 800px);}
      .stanza{position:absolute; inset:0; display:flex; flex-direction:column; background:var(--card);border:1px solid rgba(255,255,255,.10);border-radius:18px;overflow:hidden; box-shadow: 0 18px 60px rgba(0,0,0,.35); will-change: transform; touch-action: none;}
      .stanza[data-depth="1"]{transform: translateY(8px) scale(0.985); opacity:0.98}
      .stanza[data-depth="2"]{transform: translateY(16px) scale(0.97); opacity:0.96}
      .stanza[data-depth="3"]{transform: translateY(24px) scale(0.955); opacity:0.94}
      .stanza.hidden{display:none}
      .stanza.dragging{transition:none !important; cursor:grabbing}
      .stanza.animate{transition: transform 220ms ease, opacity 220ms ease}
      .sub{margin-top:4px;font-size:12px;color:var(--muted)}
      .img{width:100%; flex-shrink:0; aspect-ratio:16/9; background: rgba(200,162,74,.08); position:relative; overflow:hidden}
      .img button{all:unset; cursor:pointer; display:block; width:100%; height:100%}
      .img img{width:100%;height:100%;object-fit:cover;display:block}
      .zoomHint{position:absolute; right:10px; bottom:10px; font-size:12px; color:rgba(232,234,242,.92); background:rgba(0,0,0,.35); padding:6px 8px; border-radius:999px; border:1px solid rgba(255,255,255,.18); backdrop-filter: blur(6px)}
      .content{padding:14px 14px 20px; overflow-y:auto; flex:1; min-height:0}
      .sa{white-space:pre-wrap;font-size:18px;line-height:1.55}
      .label{font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
      .label+.label{margin-top:12px}
      .content .label:not(:first-child){margin-top:14px}
      .para{margin:6px 0 0;line-height:1.6}

      /* nav arrows on card (desktop only) */
      .nav-arrow{position:absolute; top:50%; transform:translateY(-50%); z-index:200; background:rgba(200,162,74,.15); border:1px solid rgba(200,162,74,.3); color:var(--accent); width:44px; height:44px; border-radius:50%; display:none; align-items:center; justify-content:center; cursor:pointer; font-size:20px; transition: background .15s, opacity .15s; backdrop-filter:blur(6px)}
      .nav-arrow:hover{background:rgba(200,162,74,.3)}
      .nav-arrow:disabled{opacity:.25; cursor:default; pointer-events:none}
      .nav-arrow.prev{left:-56px}
      .nav-arrow.next{right:-56px}
      @media(min-width:641px){
        .nav-arrow{display:flex}
      }
      @media(max-width:980px) and (min-width:641px){
        .nav-arrow.prev{left:8px}
        .nav-arrow.next{right:8px}
        .nav-arrow{background:rgba(0,0,0,.5); border-color:rgba(255,255,255,.15)}
        .nav-arrow:hover{background:rgba(0,0,0,.7)}
      }

      dialog{border:none; padding:0; background:transparent; max-width:min(96vw, 980px)}
      dialog::backdrop{background:rgba(0,0,0,.72)}
      .modal{background:rgba(18,20,28,.98); border:1px solid rgba(255,255,255,.12); border-radius:16px; overflow:hidden}
      .modal img{display:block; width:100%; height:auto; background:#0b0c10}
      .modalTop{display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px 12px; color:var(--muted)}
      .modalTop strong{color:var(--text); font-weight:600}
      .closeBtn{all:unset; cursor:pointer; padding:6px 10px; border-radius:10px; border:1px solid rgba(255,255,255,.14)}
      .lang-block{display:block}
      .lang-ta{display:none}
      .gloss{margin:8px 0 0;padding-left:16px;color:var(--muted)}
      .gloss li{margin:4px 0}
      details{border-top:1px solid rgba(255,255,255,.08); padding-top:10px}
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="header">
        <a href="/" class="back" aria-label="All Daskams">&#8592;</a>
        <h1 class="title">Daskam {daskam.id}</h1>
        <span class="sep">&middot;</span>
        <span class="sloka-count" id="cardCount">Sloka 1 / {daskam.stanzas.length}</span>
        <div class="lang-sw">
          <a href="#" data-stanzalang="sa" class="active">SA</a>
          <span style="opacity:.4">|</span>
          <a href="#" data-stanzalang="en">EN</a>
        </div>
      </div>
      <div class="dots-row" aria-label="Progress">
        <button class="dot-arrow" id="dotPrev" type="button" disabled aria-label="Previous">&#8592;</button>
        {daskam.stanzas.map((s, i) => (
          <span class={`dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Sloka ${s.n}`}></span>
        ))}
        <button class="dot-arrow" id="dotNext" type="button" aria-label="Next">&#8594;</button>
      </div>

      <div class="stack-wrap">
        <button class="nav-arrow prev" id="prevBtn" type="button" disabled aria-label="Previous sloka">&#8592;</button>
        <button class="nav-arrow next" id="nextBtn" type="button" aria-label="Next sloka">&#8594;</button>

        <div class="stack" id="stack" aria-label="Slokas">
        {daskam.stanzas.map((s, idx) => (
          <section class="stanza" data-index={idx} data-depth={idx} aria-label={`Sloka ${s.n}`}>
            <div class="img">
              <button type="button" data-fullsrc={s.image.src} data-alt={s.image.alt} onclick="window.__na_openImg?.(this.dataset.fullsrc, this.dataset.alt)">
                <img src={s.image.src} alt={s.image.alt} onerror="this.remove();" />
              </button>
              <span class="zoomHint">Tap to zoom</span>
            </div>
            <div class="content">
              <div class="label">Stanza {s.n}</div>
              <div class="sa stanza-block stanza-sa">{s.sanskrit}</div>
              <div class="sa stanza-block stanza-en" style="display:none">{s.stanza_roman || 'English stanza coming soon.'}</div>

              <div class="label">Commentary</div>
              <p class="para">{s.commentary_en}</p>
            </div>
          </section>
        ))}
        </div>
      </div>

      <dialog id="imgModal">
        <div class="modal">
          <div class="modalTop">
            <strong id="imgModalTitle">Image</strong>
            <button class="closeBtn" type="button" onclick="document.getElementById('imgModal').close()">Close</button>
          </div>
          <img id="imgModalImg" alt="" />
        </div>
      </dialog>

      <script>
        // Stanza language switcher
        const setStanzaLang = (lang) => {
          const showEn = lang === 'en';
          document.querySelectorAll('.stanza-sa').forEach(el => el.style.display = showEn ? 'none' : 'block');
          document.querySelectorAll('.stanza-en').forEach(el => el.style.display = showEn ? 'block' : 'none');
          document.querySelectorAll('[data-stanzalang]').forEach(a => {
            a.classList.toggle('active', a.dataset.stanzalang === lang);
          });
          try { localStorage.setItem('na_stanza_lang', lang); } catch {}
        };
        const initialLang = (new URLSearchParams(window.location.search).get('stanza') || localStorage.getItem('na_stanza_lang') || 'sa');
        setStanzaLang(initialLang);
        document.querySelectorAll('[data-stanzalang]').forEach(a => {
          a.addEventListener('click', (e) => { e.preventDefault(); setStanzaLang(a.dataset.stanzalang); });
        });

        // Card navigation
        const dots = Array.from(document.querySelectorAll('[data-dot]'));
        const countEl = document.getElementById('cardCount');
        const cards = Array.from(document.querySelectorAll('#stack > section.stanza'));
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const dotPrev = document.getElementById('dotPrev');
        const dotNext = document.getElementById('dotNext');
        const stack = document.getElementById('stack');
        let current = 0;
        let busy = false;

        const updateStack = () => {
          for (let i = 0; i < cards.length; i++) {
            const depth = i - current;
            const c = cards[i];
            c.classList.remove('animate', 'dragging', 'top');
            c.style.transform = '';
            c.style.opacity = '';
            if (depth < 0) { c.classList.add('hidden'); continue; }
            c.classList.remove('hidden');
            c.style.zIndex = String(100 - depth);
            c.dataset.depth = String(Math.min(depth, 3));
            if (depth > 3) c.style.opacity = '0';
            if (depth === 0) { c.classList.add('top'); c.scrollTop = 0; }
          }
          dots.forEach((d,i) => d.classList.toggle('active', i === current));
          if (countEl) countEl.textContent = `Sloka ${current+1} / ${cards.length}`;
          const atStart = current === 0;
          const atEnd = current === cards.length - 1;
          prevBtn.disabled = atStart;
          nextBtn.disabled = atEnd;
          dotPrev.disabled = atStart;
          dotNext.disabled = atEnd;
        };

        const goNext = () => {
          if (busy || current >= cards.length - 1) return;
          busy = true;
          const card = cards[current];
          card.classList.add('animate');
          card.style.transform = `translateX(${-(window.innerWidth + 200)}px) rotate(-12deg)`;
          card.style.opacity = '0';
          setTimeout(() => { current++; updateStack(); busy = false; }, 260);
        };

        const goPrev = () => {
          if (busy || current <= 0) return;
          busy = true;
          current--;
          const card = cards[current];
          card.classList.remove('hidden');
          card.style.zIndex = '100';
          card.style.transform = `translateX(${window.innerWidth + 200}px) rotate(12deg)`;
          card.style.opacity = '0';
          card.offsetHeight; // force reflow
          card.classList.add('animate');
          card.style.transform = '';
          card.style.opacity = '';
          setTimeout(() => { updateStack(); busy = false; }, 260);
        };

        updateStack();

        // all arrow buttons
        prevBtn.addEventListener('click', goPrev);
        nextBtn.addEventListener('click', goNext);
        dotPrev.addEventListener('click', goPrev);
        dotNext.addEventListener('click', goNext);

        // keyboard
        document.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowLeft') goPrev();
          else if (e.key === 'ArrowRight') goNext();
        });

        // swipe logic
        let startX = 0, startY = 0, dx = 0;
        let dragging = false, decided = false, isHorizontal = false;

        // Use touch events for reliable mobile swipe across the whole card
        let lastTouchY = 0;
        stack.addEventListener('touchstart', (e) => {
          if (busy) return;
          const card = cards[current];
          if (!card) return;
          dragging = true; decided = false; isHorizontal = false; dx = 0;
          card.classList.remove('animate');
          startX = e.touches[0].clientX;
          startY = e.touches[0].clientY;
          lastTouchY = startY;
        }, { passive: true });

        stack.addEventListener('touchmove', (e) => {
          if (!dragging || busy) return;
          const card = cards[current];
          if (!card) return;
          const tx = e.touches[0].clientX;
          const ty = e.touches[0].clientY;
          const mx = tx - startX;
          const my = ty - startY;
          if (!decided && (Math.abs(mx) > 10 || Math.abs(my) > 10)) {
            decided = true;
            isHorizontal = Math.abs(mx) > Math.abs(my);
            if (isHorizontal) card.classList.add('dragging');
          }
          if (isHorizontal) {
            if (e.cancelable) e.preventDefault();
            dx = mx;
            card.style.transform = `translateX(${dx}px) rotate(${Math.max(-8, Math.min(8, dx / 22))}deg)`;
          } else {
            // manually scroll the content area
            const content = card.querySelector('.content');
            if (content) content.scrollTop += lastTouchY - ty;
          }
          lastTouchY = ty;
        }, { passive: false });

        const endSwipe = () => {
          if (!dragging) return;
          dragging = false;
          const card = cards[current];
          if (!card) return;
          card.classList.remove('dragging');
          if (!isHorizontal) { card.style.transform = ''; return; }
          const threshold = Math.min(80, window.innerWidth * 0.2);
          if (dx < -threshold && current < cards.length - 1) {
            card.style.transform = '';
            goNext();
          } else if (dx > threshold && current > 0) {
            card.style.transform = '';
            goPrev();
          } else {
            card.classList.add('animate');
            card.style.transform = '';
          }
        };

        stack.addEventListener('touchend', endSwipe);
        stack.addEventListener('touchcancel', endSwipe);

        // Pointer events for desktop mouse drag
        stack.addEventListener('pointerdown', (e) => {
          if (busy || e.pointerType === 'touch') return;
          const card = cards[current];
          if (!card) return;
          dragging = true; decided = false; isHorizontal = false; dx = 0;
          card.classList.remove('animate');
          startX = e.clientX; startY = e.clientY;
        });
        window.addEventListener('pointermove', (e) => {
          if (!dragging || busy || e.pointerType === 'touch') return;
          const card = cards[current];
          if (!card) return;
          const mx = e.clientX - startX;
          const my = e.clientY - startY;
          if (!decided && (Math.abs(mx) > 10 || Math.abs(my) > 10)) {
            decided = true;
            isHorizontal = Math.abs(mx) > Math.abs(my);
            if (isHorizontal) card.classList.add('dragging');
          }
          if (!isHorizontal) return;
          dx = mx;
          card.style.transform = `translateX(${dx}px) rotate(${Math.max(-8, Math.min(8, dx / 22))}deg)`;
        }, { passive: true });
        window.addEventListener('pointerup', (e) => { if (e.pointerType !== 'touch') endSwipe(); });
        window.addEventListener('pointercancel', (e) => { if (e.pointerType !== 'touch') endSwipe(); });

        // image zoom modal
        window.__na_openImg = (src, alt) => {
          const dlg = document.getElementById('imgModal');
          document.getElementById('imgModalImg').src = src;
          document.getElementById('imgModalImg').alt = alt || '';
          document.getElementById('imgModalTitle').textContent = alt || 'Image';
          dlg.showModal();
        };
        document.getElementById('imgModal')?.addEventListener('click', (e) => {
          if (e.target?.id === 'imgModal') e.target.close();
        });
      </script>

    </div>
  </body>
</html>
